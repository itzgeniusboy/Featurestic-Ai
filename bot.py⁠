import os
import sys
import telebot
from telebot.types import InlineKeyboardMarkup, InlineKeyboardButton
from openai import OpenAI

# 1. Telegram Bot Token Setup
BOT_TOKEN = os.environ.get("TELEGRAM_BOT_TOKEN")
print(f"--- HARDCODED DEPLOYMENT LOG ---")
print(f"DEBUG: TELEGRAM_BOT_TOKEN received in script: {bool(BOT_TOKEN)}")

if not BOT_TOKEN:
    print("❌ CRITICAL ERROR: Environment variable me token nahi mila!")
    sys.exit(1)

try:
    bot = telebot.TeleBot(BOT_TOKEN)
    print("🤖 TeleBot connected successfully.")
except Exception as e:
    print(f"❌ CRITICAL ERROR: Telegram initialization failed: {e}")
    sys.exit(1)

BOT_USERNAME = "FeaturesticAibot"

# 2. GitHub Tokens List
GITHUB_TOKENS = []
if os.environ.get("TOKEN1"):
    GITHUB_TOKENS.append(os.environ.get("TOKEN1"))
if os.environ.get("TOKEN2"):
    GITHUB_TOKENS.append(os.environ.get("TOKEN2"))

print(f"DEBUG: GitHub Tokens loaded count: {len(GITHUB_TOKENS)}")

if not GITHUB_TOKENS or "ghp_" not in GITHUB_TOKENS[0]:
    print("⚠️ WARNING: Real GitHub AI Token nahi mila, default fallback use hoga.")
    GITHUB_TOKENS = ["dummy_token_to_prevent_crash"]

current_token_index = 0


def get_openai_client():
    global current_token_index
    return OpenAI(
        base_url="https://models.inference.ai.azure.com",
        api_key=GITHUB_TOKENS[current_token_index]
    )


def rotate_token():
    global current_token_index
    current_token_index = (current_token_index + 1) % len(GITHUB_TOKENS)


MODELS = ["meta-llama-3.1-70b-instruct", "gpt-4o-mini", "mistral-large-2407"]

SYSTEM_PROMPT = """
You are an expert Android Game Developer, Reverse Engineer, and Cyber Security Analyst.
You chat casually and friendly in Hinglish like a helpful peer.
Help users write/debug memory patching code in C++ (offsets, hooks, libil2cpp), design Android ImGui Mod Menus, and handle JNI/NDK.
"""


@bot.message_handler(commands=['start'])
def send_welcome(message):
    print(f"DEBUG: Processing /start from {message.chat.id}")
    if message.chat.type == "private":
        welcome_text = (
            "👋 **Hello Bhai! Welcome to Modding AI Assistant Bot.**\n\n"
            "Main aapki help C++, Java, Python code check karne, Mod Menu layouts, "
            "aur Android reverse engineering me kar sakta hoon.\n\n"
            "Mujhe apne group me add karne ke liye niche diye gaye button par click karein! 👇"
        )
        add_to_group_url = f"https://t.me/{BOT_USERNAME}?startgroup=true"
        markup = InlineKeyboardMarkup()
        add_button = InlineKeyboardButton(text="➕ Add to Group ➕", url=add_to_group_url)
        markup.add(add_button)
        try:
            bot.send_message(message.chat.id, welcome_text, parse_mode="Markdown", reply_markup=markup)
        except Exception as e:
            print(f"❌ Telegram send failed (welcome): {e}")


@bot.message_handler(func=lambda message: True)
def handle_chat(message):
    text = message.text if message.text else ""
    is_private = message.chat.type == "private"

    is_tagged = f"@{BOT_USERNAME}" in text
    is_command = text.startswith("/ai ")

    if is_private or is_tagged or is_command:
        print(f"DEBUG: Message detected: {text[:15]}...")
        try:
            bot.send_chat_action(message.chat.id, 'typing')
        except Exception as e:
            print(f"⚠️ send_chat_action failed: {e}")

        clean_text = text.replace(f"@{BOT_USERNAME}", "").replace("/ai ", "").strip()

        if not clean_text:
            try:
                bot.reply_to(message, "Ji bhai, bolo kya help chahiye?")
            except Exception as e:
                print(f"❌ Telegram send failed: {e}")
            return

        ai_reply = None
        for _ in range(len(GITHUB_TOKENS)):
            client = get_openai_client()
            for model_name in MODELS:
                try:
                    response = client.chat.completions.create(
                        messages=[
                            {"role": "system", "content": SYSTEM_PROMPT},
                            {"role": "user", "content": clean_text}
                        ],
                        model=model_name,
                        temperature=0.5,
                        max_tokens=2048
                    )
                    ai_reply = response.choices[0].message.content
                    break
                except Exception as e:
                    print(f"⚠️ Model {model_name} Error: {e}")
                    continue
            if ai_reply:
                break
            rotate_token()

        try:
            if ai_reply:
                bot.reply_to(message, ai_reply)
            else:
                bot.reply_to(message, "⏳ Server thoda busy hai, please 1 minute baad try karein.")
        except Exception as e:
            print(f"❌ Telegram send failed (reply): {e}")


if __name__ == "__main__":
    print("🤖 Loop validation passed. Bot infinity polling active!")
    try:
        bot.infinity_polling(timeout=20, long_polling_timeout=10, skip_pending=True)
    except Exception as e:
        print(f"❌ Crash Log: {e}")
