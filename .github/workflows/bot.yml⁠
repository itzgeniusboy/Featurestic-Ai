name: 24/7 Telegram AI Bot

on:
  push:
    branches: [ main ]
  schedule:
    # Har 5 ghante 50 minute ka loop chalane ke liye cron setup
    - cron: '0 */5 * * *'
  workflow_dispatch: # Manual start karne ka button trigger

jobs:
  run-bot:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout Code From Repository
      uses: actions/checkout@v4

    - name: Set up Python Environment
      uses: actions/setup-python@v5
      with:
        python-version: '3.10'

    - name: Install PyTelegramBotAPI and OpenAI Directly
      run: |
        python -m pip install --upgrade pip
        pip install pyTelegramBotAPI==4.12.0 openai==1.12.0

    - name: Run Telegram Bot With Safe Timeout
      env:
        TELEGRAM_BOT_TOKEN: ${{ secrets.TELEGRAM_BOT_TOKEN }}
        TOKEN1: ${{ secrets.TOKEN1 }}
        TOKEN2: ${{ secrets.TOKEN2 }}
      run: |
        # 5 hours 50 minutes = 21000 seconds ke baad automatic job safely cancel hogi
        timeout 21000 python bot.py || true
